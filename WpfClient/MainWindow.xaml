<Window x:Class="WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI 問答系統" Height="350" Width="550">
    <Grid>
        <StackPanel Margin="20">
            <!-- 使用者輸入框 -->
            <TextBox x:Name="UserInput" FontSize="16" Height="50" Margin="0,0,0,10" MaxLength="100"/>

            <!-- 發送按鈕 -->
            <Button Content="發送訊息" Click="SendMessage" FontSize="16" Height="30" Margin="0,0,0,10"/>

            <!-- 顯示 AI 回應，增加 ScrollViewer -->
            <TextBlock x:Name="AiResponse" FontSize="16" TextWrapping="Wrap" 
                           Text="AI 回應將顯示在這裡" Height="160" Margin="0,0,0,10"/>
        </StackPanel>
    </Grid>
</Window>
